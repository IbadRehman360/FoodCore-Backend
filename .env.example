# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=foodcure
POSTGRES_PASSWORD=secret
POSTGRES_DB=foodcure_db

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/foodcure

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─── Apple OAuth ─────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# ─── SendGrid ────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@foodcure.app
SENDGRID_FROM_NAME=FoodCure

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Firebase (FCM Push Notifications) ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Agora (Video Calls) ──────────────────────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ─── AWS S3 (File Uploads) ───────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=foodcure-uploads

# ─── AI / External Food DB ───────────────────────────────────────────────────
OPENAI_API_KEY=
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=
USDA_API_KEY=

# ─── Encryption ──────────────────────────────────────────────────────────────
AES_ENCRYPTION_KEY=32_char_key_change_in_production_!

# ─── Rate Limiting ───────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
